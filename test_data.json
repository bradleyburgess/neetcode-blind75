{
    "01_contains_duplicate": [
        {
            "input": [1, 2, 3, 1],
            "expected": true
        },
        {
            "input": [1, 2, 3, 1],
            "expected": true
        },
        {
            "input": [1, 2, 3],
            "expected": false
        },
        {
            "input": [],
            "expected": false
        },
        {
            "input": [1],
            "expected": false
        },
        {
            "input": [1, 1],
            "expected": true
        }
    ],
    "02_valid_anagram": [
        {
            "input": ["anagram", "nagaram"],
            "expected": true
        },
        {
            "input": ["rat", "car"],
            "expected": false
        },
        {
            "input": ["", ""],
            "expected": true
        },
        {
            "input": ["a", "a"],
            "expected": true
        },
        {
            "input": ["a", "b"],
            "expected": false
        },
        {
            "input": ["jar", "jam"],
            "expected": false
        },
        {
            "input": ["aabbcc", "abcabc"],
            "expected": true
        },
        {
            "input": ["abc", "abcd"],
            "expected": false
        },
        {
            "input": ["Are you alright?", "authorial grey"],
            "expected": true
        }
    ],
    "03_two_sum": [
        {
            "input": [[2, 7, 11, 15], 9],
            "expected": [0, 1]
        },
        {
            "input": [[3, 2, 4], 6],
            "expected": [1, 2]
        },
        {
            "input": [[3, 3], 6],
            "expected": [0, 1]
        },
        {
            "input": [[1, 5, 4, 7], 8],
            "expected": [0, 3]
        },
        {
            "input": [[-1, -2, -3, -4, -5], -8],
            "expected": [2, 4]
        },
        {
            "input": [[0, 4, 3, 0], 0],
            "expected": [0, 3]
        },
        {
            "input": [[1, 2, 3, 4, 5], 9],
            "expected": [3, 4]
        },
        {
            "input": [[10, 20, 40, 50, 60, 70], 50],
            "expected": [0, 2]
        },
        {
            "input": [[5, 75, 25], 100],
            "expected": [1, 2]
        },
        {
            "input": [[1, 3, 4, 2], 6],
            "expected": [2, 3]
        },
        {
            "input": [[5, 5], 10],
            "expected": [0, 1]
        },
        {
            "input": [[1, 5, 3, 5], 10],
            "expected": [1, 3]
        },
        {
            "input": [[0, 4, 3, 2], 6],
            "expected": [1, 3]
        },
        {
            "input": [[80, 20, 40, 10, 30], 70],
            "expected": [2, 4]
        },
        {
            "input": [[1, 3, 4, 2], 6],
            "expected": [2, 3]
        },
        {
            "input": [[1, 3, 2, 5, 7], 10],
            "expected": [1, 4]
        }
    ],
    "04_group_anagrams": [
        {
            "input": ["eat", "tea", "tan", "ate", "nat", "bat"],
            "expected": [["bat"], ["nat", "tan"], ["ate", "eat", "tea"]]
        },
        {
            "input": ["abc", "cab", "bca", "acb", "cba", "bac"],
            "expected": [["abc", "acb", "bac", "bca", "cab", "cba"]]
        },
        {
            "input": ["one", "two", "three"],
            "expected": [["one"], ["three"], ["two"]]
        },
        {
            "input": [""],
            "expected": [[""]]
        },
        {
            "input": [],
            "expected": []
        },
        {
            "input": ["a"],
            "expected": [["a"]]
        },
        {
            "input": ["", "", "a", "a", "b"],
            "expected": [["", ""], ["a", "a"], ["b"]]
        }
    ]
}
